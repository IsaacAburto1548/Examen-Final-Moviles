<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PastureControl" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark</item>

        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.PastureControl.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />
    <style name="Theme.PastureControl.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />
</resources>
